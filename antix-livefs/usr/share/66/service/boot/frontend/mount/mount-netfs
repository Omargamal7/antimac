[Main]
Type = oneshot
Version = %%version%%
Description = "Mount no-network filesystem"
User = ( root )
Depends=( mount-rw )
StdOut = s6log:%%livedir%%/log/mount-netfs

[Start]
Execute =
(
    if { 66-yeller -cdp mount-netfs -1 /dev/console implement no_netdev directives }
    if -nt {

        mount -a -t "nosysfs,nonfs,nonfs4,nosmbfs,nocifs" -O no_netdev

    }
    66-yeller -fcdp mount-netfs -1 /dev/console crashed!
)
