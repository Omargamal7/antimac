# Install for edge cases and not considered as applications
application-in-library-section libs usr/bin/cpan5.40-x86_64-linux-gnu usr/bin/perl5.40-x86_64-linux-gnu
# Documentation describes files in this directory
package-contains-documentation-outside-usr-share-doc usr/lib/x86_64-linux-gnu/perl/debian-config-data-5.40.0/README
# There is logic in the unicode handling code which deals with this typo
spelling-error-in-binary usr/lib/x86_64-linux-gnu/libperl.so.5.40.0 Inseperable Inseparable
# the XS module .so files are private plugins, not general shared libraries
library-not-linked-against-libc [usr/lib/x86_64-linux-gnu/perl/5.40.0/auto/Devel/Peek/Peek.so]
