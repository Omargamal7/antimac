#!/usr/bin/execlineb -P
envfile /etc/s6-rc/config/mount-cgroups.conf

importas -uD "hybrid" CGROUP_MODE CGROUP_MODE
importas -uD "none" CGROUP_CONTROLLERS CGROUP_CONTROLLERS
importas -uD "true" HAVE_CONTROLLER1_GROUPS HAVE_CONTROLLER1_GROUPS

exec sh /etc/s6-rc/scripts/mount-cgroups/mount-cgroups.sh $CGROUP_MODE $CGROUP_CONTROLLERS $HAVE_CONTROLLER1_GROUPS
