#!/usr/bin/execlineb -P

if { pipeline { s6-rc -ba list } grep -qFx mount-filesystems }

envfile /etc/s6-rc/config/ttyS.conf
importas -uD "yes" SPAWN SPAWN
importas -sCuD "" ARGS ARGS
importas -sCuD "agetty" GETTY GETTY

if -t { test -e /dev/ttyAMA0 }
if -t { test ${SPAWN} = "yes" }
	exec ${GETTY} ${ARGS}
