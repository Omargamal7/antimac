#!/bin/sh
# IceWM + Tint2 session.
# Stop IceWM's tray helper, then reset/start tint2 if available.
pkill -x icewmtray 2>/dev/null || true
pkill -x tint2 2>/dev/null || true
command -v tint2 >/dev/null 2>&1 && tint2 &
# Fail fast if icewm is not installed in the current rootfs.
command -v icewm >/dev/null 2>&1 || { echo "icewm not found" >&2; exit 1; }
exec icewm
