if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -x "/etc/init.d/dhcpcd" ]; then
		update-rc.d dhcpcd defaults >/dev/null || exit 1
	fi
