#! /bin/sh
#
# s6-rc-init-diversity prerm
#

set -e

case "$1" in
		remove|purge)
			# Exit with error code if s6-rc is detected as PID 1
			if [ $(ps -p1 | grep -ic "s6-svscan") -eq 1 ] && [ -e /run/s6-rc ]; then
				echo "s6-rc has been detected as the running init - stopping here"
				exit 1
			fi
		;;	
		
		*) : 
		;;
esac




exit 0
