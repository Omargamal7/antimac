#! /bin/sh
  
set -e

if [ "$1" != "upgrade" ]; then
    update-alternatives --remove locate /usr/bin/plocate
fi

# Automatically added by dh_installsystemd/13.20
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	deb-systemd-invoke stop 'plocate-updatedb.service' 'plocate-updatedb.timer' >/dev/null || true
fi
