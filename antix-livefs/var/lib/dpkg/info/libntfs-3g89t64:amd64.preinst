#!/bin/sh

set -e

# begin-remove-after: released:trixie
if test "$1" = upgrade || test "$1" = install; then
	for f in libntfs-3g.so.89 libntfs-3g.so.89.0.0; do
		dpkg-divert --no-rename --package libntfs-3g89t64 --divert "/lib/x86_64-linux-gnu/$f.usr-is-merged" --add "/lib/x86_64-linux-gnu/$f"
	done
fi
# end-remove-after


