#!/bin/sh

set -e

if [ upgrade = "$1" ] && dpkg --compare-versions "$2" lt 0.6-1; then
	update-alternatives --remove-all sysusers
fi

# Automatically added by dh_installinit/13.24.2
if [ "$1" = "install" ] && [ -n "$2" ] && [ -e "/etc/init.d/opensysusers" ] ; then
	chmod +x "/etc/init.d/opensysusers" >/dev/null || true
fi
# End automatically added section


exit 0
