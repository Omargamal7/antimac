type      = scripted

command   = /bin/sh -c "install -m0664 -o root -g utmp /dev/null /run/utmp; \
			if [ ! -e /var/log/wtmp ]; then install -m0664 -o root -g utmp /dev/null /var/log/wtmp ; fi; \
			if [ ! -e /var/log/btmp ]; then install -m0600 -o root -g utmp /dev/null /var/log/btmp ; fi; \
			if pgrep -x "bootlogd" >/dev/null; then pkill bootlogd; fi; \
			rm -rf /etc/nologin /forcefsck /forcequotacheck /fastboot"

restart   = false

waits-for = fsck